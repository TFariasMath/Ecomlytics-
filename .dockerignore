.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Documentation (not needed in container)
docs/
*.md
!README.md

# Scripts that shouldn't be in container
test_*.py
analyze_*.py
calc_*.py
check_*.py
compare_*.py
deep_*.py
find_*.py
generate_*.py
get_*.py
identify_*.py
quick_*.py
verify_*.py
view_*.py
resumen_*.py
