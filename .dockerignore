# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
venv/
env/

# Environment files
.env
.env.local
.env.*.local

# Databases (will be mounted as volumes)
data/*.db
*.db

# Logs (will be mounted as volumes)
logs/
*.log

# Backups (will be mounted as volumes)
backups/
security_backups/

# Exports (will be mounted as volumes)
exports/

